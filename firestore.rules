rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      // NOTE: Temporarily relaxed for debugging
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- User Profiles & Company Settings ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUserProfile(incoming())
        && incoming().uid == userId
        && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'companyName', 'companyRut', 
          'companyAddress', 'companyPhone', 'companyLogo', 
          'companyEmail', 'companyWebsite', 'updatedAt'
        ]);
    }

    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.keys().hasAll(['uid', 'email']) && data.keys().size() <= 15;
    }

    // --- Generic Owner-Scoped Collections ---
    // This pattern secures multiple collections where ownership is defined by 'ownerId'
    match /{collectionName}/{docId} {
      allow list: if isSignedIn();
      allow get: if isOwner(resource.data.ownerId) && isValidId(docId);
      allow create: if isOwner(incoming().ownerId) 
        && isValidId(docId)
        && collectionName in [
          'contacts', 'projects', 'inventory', 'riskRecords', 
          'employees', 'suppliers', 'invoices', 'financeProcesses', 
          'financeTasks', 'documents'
        ];
      allow update: if isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && isValidId(docId);
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
