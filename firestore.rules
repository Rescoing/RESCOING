rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      // NOTE: Temporarily relaxed for debugging. Re-enable email_verified in production.
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rescoing@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isApproved() {
      // Admins are always approved
      return request.auth.token.email == 'rescoing@gmail.com' || (
        isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accessStatus', 'pending') == 'approved'
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- User Profiles & Company Settings ---
    match /users/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow delete: if isAdmin() || userId == 'invite_' + request.auth.token.email;
      allow create: if (
        (isOwner(userId) 
          && incoming().uid == userId
          && incoming().email == request.auth.token.email
          && (
            request.auth.token.email == 'rescoing@gmail.com' ||
            exists(/databases/$(database)/documents/users/$('invite_' + request.auth.token.email)) ||
            (incoming().role == 'user' && incoming().accessStatus == 'pending')
          )
        ) || isAdmin()
      ) && isValidUserProfile(incoming());
      
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && (
          // Admin can update everything including role and permissions
          isAdmin() || (
            isOwner(userId) && 
            incoming().diff(existing()).affectedKeys().hasOnly([
              'displayName', 'photoURL', 'companyName', 'companyRut', 
              'companyAddress', 'companyPhone', 'companyLogo', 
              'companyEmail', 'companyWebsite', 'updatedAt'
            ])
          )
        );
    }

    match /internal_messages/{messageId} {
      allow create: if isSignedIn() && (incoming().senderId == request.auth.uid || isAdmin());
      allow read, list, update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid || 
        resource.data.isGroup == true || 
        isAdmin()
      );
    }

    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.keys().hasAll(['uid', 'email']) && data.keys().size() <= 15;
    }

    // --- Generic Owner-Scoped Collections ---
    // This pattern secures multiple collections where ownership is defined by 'ownerId'
    match /{collectionName}/{docId} {
      allow list: if isApproved() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow get: if isApproved() && (isOwner(resource.data.ownerId) || isAdmin()) && isValidId(docId);
      allow create: if isApproved() && (isOwner(incoming().ownerId) || isAdmin())
        && isValidId(docId)
        && collectionName in [
          'contacts', 'projects', 'inventory', 'riskRecords', 
          'employees', 'suppliers', 'invoices', 'financeProcesses', 
          'financeTasks', 'documents', 'library', 'folioCounters',
          'attendance', 'payrolls', 'purchaseInvoices', 'paymentNotices',
          'notifications', 'inventory_movements', 'systemLogs', 'siiDocuments',
          'accountingEntries'
        ];
      allow update: if isApproved() && (isOwner(existing().ownerId) || isAdmin())
        && incoming().ownerId == existing().ownerId
        && isValidId(docId);
      allow delete: if isApproved() && (isOwner(existing().ownerId) || isAdmin());
    }
  }
}
