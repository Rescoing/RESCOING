{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and company settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "companyName": { "type": "string" },
        "companyRut": { "type": "string" },
        "companyAddress": { "type": "string" },
        "companyPhone": { "type": "string" },
        "companyLogo": { "type": "string" },
        "companyEmail": { "type": "string" },
        "companyWebsite": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "accessStatus": { "type": "string", "enum": ["pending", "approved", "denied"] },
        "permissions": { 
          "type": "object",
          "properties": {
            "dashboard": { "type": "boolean" },
            "crm": { "type": "boolean" },
            "inventory": { "type": "boolean" },
            "operations": { "type": "boolean" },
            "finance": { "type": "boolean" },
            "documents": { "type": "boolean" },
            "suppliers": { "type": "boolean" },
            "hr": { "type": "boolean" },
            "library": { "type": "boolean" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Contact": {
      "title": "Contact",
      "description": "CRM Contact",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "Project": {
      "title": "Project",
      "description": "Project record",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Item in inventory",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "RiskRecord": {
      "title": "Risk Record",
      "description": "Risk prevention record",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "description"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee record",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "rut": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "firstName", "lastName", "rut"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier record",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "rutEmpresa": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing invoice",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "client": { "type": "string" },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "client", "totalAmount"]
    },
    "FinanceProcess": {
      "title": "Finance Process",
      "description": "Lifecycle of a sales process",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "clientName": { "type": "string" },
        "currentStage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "clientName"]
    },
    "FinanceTask": {
      "title": "Finance Task",
      "description": "Reminder or task for finance",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title"]
    },
    "Document": {
      "title": "Document",
      "description": "Business document (Quotation, PO, etc)",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "type": { "type": "string" },
        "folio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "type", "folio"]
    },
    "LibraryItem": {
      "title": "Library Item",
      "description": "Stored file in the library",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "docType": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileData": { "type": "string", "description": "Base64 or URL" },
        "folio": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "docType", "fileName", "folio"]
    },
    "FolioCounter": {
      "title": "Folio Counter",
      "description": "Counter for document folios",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "docType": { "type": "string" },
        "lastFolio": { "type": "number" }
      },
      "required": ["ownerId", "docType", "lastFolio"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and company settings"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "CRM Contacts"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project management"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory management"
    },
    "/riskRecords/{recordId}": {
      "schema": "RiskRecord",
      "description": "Risk prevention records"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Human Resources"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Supplier management"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing and Invoices"
    },
    "/financeProcesses/{processId}": {
      "schema": "FinanceProcess",
      "description": "Finance Sales Processes"
    },
    "/financeTasks/{taskId}": {
      "schema": "FinanceTask",
      "description": "Finance Tasks and Reminders"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Business Documents"
    },
    "/library/{itemId}": {
      "schema": "LibraryItem",
      "description": "Digital library files"
    },
    "/folioCounters/{counterId}": {
      "schema": "FolioCounter",
      "description": "Counters for sequential folios"
    }
  }
}
